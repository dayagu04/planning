    "version": "0.2.0",
    "configurations": [
        {
            "name": "(gdb) 启动",
            "type": "cppdbg",
            "request": "launch",
            "program": "/usr/bin/mainboard",
            "args": ["-d", "/asw/planning/planning.dag"],
            "stopAtEntry": false, // 不在调试入口停留
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "为 gdb 启用整齐打印",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            // "preLaunchTask": "make build",
            "miDebuggerPath": "/usr/bin/gdb"
        },
        {
            "name": "(gdb) unit_test",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/test/unit_test",
            "args": [],
            "stopAtEntry": false, // 不在调试入口停留
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "为 gdb 启用整齐打印",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            // "preLaunchTask": "make unit_test",
            "miDebuggerPath": "/usr/bin/gdb"
        }
    ]
}
