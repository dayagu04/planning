# 通过dag文件对planning进行启动
# Define all coms in DAG streaming.
module_config {
  module_library : "/asw/planning/Lib/libplanning_component.so"
  timer_components {
    class_name : "PlanningComponent"
    config {
      name : "planning"
      interval : 50
    }
  }
}

# 通过dag文件对control进行启动
# Define all coms in DAG streaming.
module_config {
  module_library : "/asw/Control/Lib/libcontrol_component.so"
  timer_components {
    class_name : "ControlComponent"
    config {
      name : "control"
      interval : 20
    }
  }
}