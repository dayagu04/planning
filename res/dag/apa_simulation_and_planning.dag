# 通过dag文件对simulation进行启动
# Define all coms in DAG streaming.
module_config {
  module_library : "/asw/planning/Lib/libapa_simulation_component.so"
  timer_components {
    class_name : "ApaSimulationComponent"
    config {
      name : "apa_simulation"
      interval : 50
    }
  }
}

# 通过dag文件对planning进行启动
# Define all coms in DAG streaming.
module_config {
  module_library : "/asw/planning/Lib/libplanning_component.so"
  timer_components {
    class_name : "PlanningComponent"
    config {
      name : "planning"
      interval : 50
    }
  }
}