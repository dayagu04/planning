PointsSet boundingbox    # 障碍物包络框坐标
PointsSet contour        # 障碍物轮廓坐标
PointFloat32 object_size              # 障碍物大小 
float32 long_distance                   # 障碍物距离车辆纵向距离（后轴）
float32 lateral_distance                # 障碍物距离车辆横向距离（后轴）
float32 orientation_angle               # 航向角
float32 orientation_angle_rate          # 航向角变化率
float32 orientaion_angle_conf           # 航向角置信度
PointFloat32 relative_vel         # 相对速度
PointFloat32 absolute_vel         # 绝对速度
float32 vel_confidence                  # 速度置信度
PointFloat32 relative_accel   # 相对加速度
PointFloat32 absolute_accel   # 绝对加速度
float32 accel_conf                      # 加速度的置信度
PointFloat32 relative_center        # 相对中心位置
PointFloat32 absolute_center        # 绝对中心位置